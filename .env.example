MONGODB_URI=mongodb+srv://<user>:<password>@ndab-meualbum.mongodb.net/meualbum
JWT_SECRET=change_me_in_production
COOKIE_DOMAIN=localhost
PORT=3000
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Email transacional (Resend)
# Deixar vazio em DEV: fallback para console.log
# Em produção: obter em resend.com
RESEND_API_KEY=

# URL do Cloud Run para o build do frontend (Firebase Hosting chama o Cloud Run diretamente)
# Deixar vazio em DEV: proxy do Vite encaminha /api → localhost:3000
# Em produção: URL do Cloud Run (ex: https://meualbum-api-xxx-rj.a.run.app)
VITE_API_URL=
